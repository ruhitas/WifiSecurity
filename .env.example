# Wireless IDS + AI Platform — environment configuration (Phase 2)
# Copy to .env and adjust. Do NOT commit real credentials.

# --- Kafka (provisioned by docker-compose) ---
WIDS_KAFKA_BOOTSTRAP=localhost:29092

# --- Redis (EXISTING host service, Docker container on 6379) ---
WIDS_REDIS_URL=redis://localhost:6379/0

# --- MSSQL (EXISTING host service) ---
# Default: LocalDB (host-only, named pipe). For container access use a full
# SQL Server / SQLEXPRESS instance with TCP enabled instead.
WIDS_MSSQL_DRIVER=ODBC Driver 18 for SQL Server
WIDS_MSSQL_SERVER=(localdb)\MSSQLLocalDB
WIDS_MSSQL_DATABASE=WirelesSecureDB
# Auth: leave user/password blank to use Windows (Trusted) authentication.
WIDS_MSSQL_USER=
WIDS_MSSQL_PASSWORD=
# Local dev against a self-signed instance cert:
WIDS_MSSQL_ENCRYPT=no
WIDS_MSSQL_TRUST_CERT=yes

# --- Elasticsearch (EXISTING host service: ES 9.1.4, TLS + auth on) ---
WIDS_ES_URL=https://localhost:9200
WIDS_ES_USERNAME=elastic
WIDS_ES_PASSWORD=
WIDS_ES_VERIFY_CERTS=false
# Our indices use this prefix so we never collide with other apps on this shared node.
WIDS_ES_INDEX_PREFIX=wids-

# --- Observability / MLOps (provisioned by docker-compose) ---
WIDS_PROMETHEUS_URL=http://localhost:9090
WIDS_GRAFANA_URL=http://localhost:3000
WIDS_MLFLOW_URL=http://localhost:5000
